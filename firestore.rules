rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow get: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();

      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == 'user';

      allow update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'phone', 'photoURL', 'cpf', 'birthDate', 'addresses'
        ]);

      allow delete: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /cursos/{courseId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Pedidos são criados pelo Worker de pagamentos, que calcula os preços
      // no servidor antes de criar o Checkout Asaas.
      allow create: if false;

      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());

      allow update: if isAdmin();
      allow delete: if false;
    }

    // Chaves dos arquivos e permissões de download são acessadas somente
    // pelo Worker com credenciais de serviço. Nunca são expostas ao navegador.
    match /digitalAssets/{assetId} {
      allow read, write: if false;
    }

    match /digitalEntitlements/{entitlementId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
