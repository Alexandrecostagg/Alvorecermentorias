{
  "name": "alvorecermentorias",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b --pretty",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "npm run test:rules && npm run test:payments && npm run test:auth && npm run test:cep",
    "test:rules": "node scripts/test-firestore-rules.mjs",
    "test:payments": "vitest run tests/asaas-worker.test.ts",
    "test:auth": "vitest run tests/auth-errors.test.ts",
    "test:cep": "vitest run tests/cep.test.ts",
    "audit:catalog": "node scripts/audit-catalog.mjs",
    "preview": "vite preview",
    "api": "json-server --watch db.json --port 4000"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "json-server": "^1.0.0-beta.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
