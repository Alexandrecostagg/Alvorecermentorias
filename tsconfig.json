{
  "compilerOptions": {
    "target": "ES2020",
    "useFeatureDetection": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    // Adicione ou altere estas duas linhas:
    "moduleResolution": "bundler", // Ou "node". "bundler" é mais moderno para Vite.
    "allowSyntheticDefaultImports": true, // Permite importações padrão para módulos sem exportação padrão explícita

    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}